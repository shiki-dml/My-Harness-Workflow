{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/harness/agents/feature_registry_curator/output.schema.json",
  "title": "feature_registry_curator output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "curation_plan",
    "registry_changes",
    "feature_changes",
    "validation_results",
    "reconciliation_summary",
    "handoff_summary",
    "recommended_next_agent",
    "suggested_next_phase",
    "requires_human_approval",
    "status"
  ],
  "properties": {
    "curation_plan": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "registry_path": {
          "type": "string"
        },
        "features_in_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "safe_update_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "registry_changes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target_path": {
          "type": "string"
        },
        "created_feature_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updated_feature_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "preserved_feature_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "merged_feature_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "skipped_feature_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocked_feature_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "feature_changes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/feature_change"
      }
    },
    "duplicate_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "dependency_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "evidence_gaps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "validation_results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validation_result"
      }
    },
    "updated_files": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/path_reason"
      }
    },
    "skipped_files": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/path_reason"
      }
    },
    "blocked_files": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/path_reason"
      }
    },
    "reconciliation_summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": {
          "type": "string"
        },
        "source_precedence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unresolved_conflicts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "handoff_summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "current_status": {
          "type": "string"
        },
        "registry_updated": {
          "type": "boolean"
        },
        "features_changed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "known_gaps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes_for_harness_orchestrator": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes_for_handoff_writer": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes_for_human": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "recommended_next_agent": {
      "type": "string",
      "enum": [
        "harness_orchestrator",
        "handoff_writer",
        "test_strategist",
        "human",
        "none"
      ]
    },
    "suggested_next_phase": {
      "type": "string",
      "enum": [
        "orchestration",
        "handoff",
        "product_planning",
        "sprint_contracting",
        "implementation",
        "qa",
        "test_strategy",
        "documentation",
        "human_review",
        "complete",
        "blocked"
      ]
    },
    "requires_human_approval": {
      "type": "boolean"
    },
    "approval_reason": {
      "type": "string"
    },
    "blocked_reason": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "registry_validated",
        "registry_updated",
        "registry_reconciled",
        "blocked_missing_steering_contract",
        "blocked_missing_orchestration_decision",
        "blocked_missing_registry",
        "blocked_invalid_registry_json",
        "blocked_duplicate_conflict",
        "blocked_missing_evidence",
        "blocked_human_approval_required",
        "blocked_scope_conflict",
        "failed_validation"
      ]
    }
  },
  "$defs": {
    "feature_change": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "feature_id",
        "name",
        "change_type",
        "previous_status",
        "new_status",
        "evidence"
      ],
      "properties": {
        "feature_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "change_type": {
          "type": "string",
          "enum": [
            "created",
            "updated",
            "status_changed",
            "evidence_added",
            "dependency_updated",
            "blocked",
            "merged",
            "skipped"
          ]
        },
        "previous_status": {
          "type": "string"
        },
        "new_status": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_record"
          }
        },
        "history_entry": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "date": {
              "type": "string"
            },
            "from_status": {
              "type": "string"
            },
            "to_status": {
              "type": "string"
            },
            "reason": {
              "type": "string"
            },
            "evidence": {
              "type": "string"
            }
          }
        }
      }
    },
    "evidence_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "reference",
        "summary"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "reference": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "result": {
          "type": "string"
        },
        "date": {
          "type": "string"
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "description",
        "evidence",
        "recommendation"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommendation": {
          "type": "string"
        }
      }
    },
    "validation_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check",
        "result",
        "evidence"
      ],
      "properties": {
        "check": {
          "type": "string"
        },
        "result": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "skipped",
            "unknown"
          ]
        },
        "evidence": {
          "type": "string"
        }
      }
    },
    "path_reason": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "reason"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      }
    }
  }
}
