{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/harness/agents/initializer_agent/output.schema.json",
  "title": "initializer_agent output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "initialization_plan",
    "created_files",
    "skipped_files",
    "blocked_files",
    "validation_results",
    "initialization_report",
    "recommended_next_agent",
    "suggested_next_phase",
    "requires_human_approval",
    "status"
  ],
  "properties": {
    "initialization_plan": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "steering_contract_status": {
          "type": "string"
        },
        "orchestration_decision_status": {
          "type": "string"
        },
        "requested_outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowed_outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "files_to_create": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "files_to_skip": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "files_to_block": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "approval_check": {
          "type": "string"
        },
        "validation_plan": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "created_files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "reason"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "skipped_files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "reason"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "blocked_files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "reason"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "file_manifest": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "action",
          "purpose",
          "source_template",
          "approval_required"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "purpose": {
            "type": "string"
          },
          "source_template": {
            "type": "string"
          },
          "approval_required": {
            "type": "boolean"
          }
        }
      }
    },
    "validation_results": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "passed": {
          "type": "boolean"
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "passed",
              "message"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "passed": {
                "type": "boolean"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "initialization_report": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": {
          "type": "string"
        },
        "created_count": {
          "type": "number"
        },
        "skipped_count": {
          "type": "number"
        },
        "blocked_count": {
          "type": "number"
        },
        "remaining_blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "workflow_state_update": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "current_phase": {
          "type": "string"
        },
        "completed_agents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "pending_agents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_decision_needed": {
          "type": "string"
        }
      }
    },
    "initialization_manifest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "initialized_by": {
          "type": "string"
        },
        "created_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "skipped_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocked_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "handoff_summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "current_status": {
          "type": "string"
        },
        "initialization_completed": {
          "type": "boolean"
        },
        "recommended_next_agent": {
          "type": "string"
        },
        "suggested_next_phase": {
          "type": "string"
        },
        "notes_for_harness_orchestrator": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "recommended_next_agent": {
      "type": "string",
      "enum": [
        "harness_orchestrator",
        "human"
      ]
    },
    "suggested_next_phase": {
      "type": "string",
      "enum": [
        "repository_mapping",
        "human_review",
        "blocked"
      ]
    },
    "requires_human_approval": {
      "type": "boolean"
    },
    "approval_reason": {
      "type": "string"
    },
    "blocked_reason": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "plan_ready",
        "initialized",
        "blocked_missing_steering_contract",
        "blocked_missing_orchestration_decision",
        "blocked_human_approval_required",
        "blocked_scope_conflict",
        "blocked_existing_file_conflict",
        "failed_validation"
      ]
    }
  }
}
